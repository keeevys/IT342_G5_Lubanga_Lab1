<?xml version="1.0" encoding="utf-8"?>
<database-config>
    <!-- MySQL Database Configuration -->
    <mysql>
        <!-- Database Server Configuration -->
        <server>
            <host>localhost</host>
            <port>3306</port>
            <database>dbit342_g5_lubanga</database>
        </server>
        
        <!-- Database Credentials -->
        <credentials>
            <username>root</username>
            <password>123456</password>
        </credentials>
        
        <!-- Connection Pool Settings -->
        <connection-pool>
            <max-connections>10</max-connections>
            <min-connections>2</min-connections>
            <timeout>30000</timeout>
        </connection-pool>
        
        <!-- JDBC Configuration -->
        <jdbc>
            <driver>com.mysql.cj.jdbc.Driver</driver>
            <url>jdbc:mysql://localhost:3306/dbit342_g5_lubanga?useSSL=false&amp;serverTimezone=UTC&amp;allowPublicKeyRetrieval=true</url>
        </jdbc>
    </mysql>
    
    <!-- API Endpoint Configuration -->
    <api>
        <base-url>http://10.0.2.2:8080/api</base-url>
        <!-- For local development on emulator, use 10.0.2.2 instead of localhost -->
        <!-- For physical device, use your computer's IP address -->
        <endpoints>
            <auth>
                <login>/auth/login</login>
                <register>/auth/register</register>
            </auth>
            <user>
                <profile>/user/profile</profile>
            </user>
        </endpoints>
    </api>
</database-config>
